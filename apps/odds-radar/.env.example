# ══════════════════════════════════════════════
#  Sheva Odds Radar — Configuração
# ══════════════════════════════════════════════

# ─── Browser ────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_HUMANIZE=true
PAGE_TIMEOUT_MS=60000
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768

# ─── Proxy (OBRIGATÓRIO para produção) ─────
# Use proxy residencial brasileiro!
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# ─── Telegram ───────────────────────────────
# Crie bot via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Scraper ────────────────────────────────
BET365_URL=https://www.bet365.bet.br
SCAN_INTERVAL_SEC=45
SPORTS=soccer
MIN_ODD=1.01
MAX_ODD=10.0
# Ligas alvo (vazio = todas)
TARGET_LEAGUES=

# ─── Sheva API ──────────────────────────────
# URL da API do Sheva para enviar odds aos dispatches
SHEVA_API_URL=http://localhost:4003

# ─── Geral ──────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
