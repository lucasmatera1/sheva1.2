{
  "name": "@sheva/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- node ./scripts/dev-api.mjs",
    "dev:basket": "dotenv -e ../../.env -- node ./scripts/dev-api-basket.mjs",
    "dev:telegram-commands": "dotenv -e ../../.env -- tsx ./scripts/telegram-command-listener.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:pull": "dotenv -e ../../.env -- prisma db pull",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@sheva/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "odbc": "^2.4.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
