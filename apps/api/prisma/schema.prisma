model player_daily_history_session_matches {
  id            BigInt                                            @id @default(autoincrement()) @db.UnsignedBigInt
  session_id    BigInt                                            @db.UnsignedBigInt
  match_order   Int                                               @db.UnsignedSmallInt
  kickoff_utc   DateTime                                          @db.DateTime(0)
  kickoff_local DateTime                                          @db.DateTime(0)
  opponent      String                                            @db.VarChar(255)
  goals_for     Int                                               @db.SmallInt
  goals_against Int                                               @db.SmallInt
  result        player_daily_history_session_matches_result
  championship  player_daily_history_session_matches_championship
  created_at    DateTime                                          @default(now()) @db.Timestamp(0)

  @@unique([session_id, match_order], map: "uq_session_match_order")
  @@index([kickoff_local], map: "idx_kickoff_local")
  @@index([session_id], map: "idx_session_id")
}

model player_daily_history_sessions {
  id                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  player              String   @db.VarChar(255)
  session_start_utc   DateTime @db.DateTime(0)
  session_end_utc     DateTime @db.DateTime(0)
  session_start_local DateTime @db.DateTime(0)
  session_end_local   DateTime @db.DateTime(0)
  session_day_local   DateTime @db.Date
  total_matches       Int      @db.UnsignedInt
  wins                Int      @db.UnsignedInt
  draws               Int      @db.UnsignedInt
  losses              Int      @db.UnsignedInt
  win_rate            Decimal  @db.Decimal(5, 2)
  created_at          DateTime @default(now()) @db.Timestamp(0)
  updated_at          DateTime @default(now()) @db.Timestamp(0)

  @@unique([player, session_start_utc], map: "uq_player_session_start")
  @@index([player, session_day_local], map: "idx_player_day")
  @@index([player, session_start_utc], map: "idx_player_start")
  @@index([session_day_local], map: "idx_session_day_local")
  @@index([session_start_utc], map: "idx_session_start_utc")
}

