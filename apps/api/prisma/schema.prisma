  occurrence_match_id String             @db.VarChar(64)
  occurrence_played_at DateTime          @db.DateTime(0)
  apx                 Decimal            @db.Decimal(5, 2)
  total_occurrences   Int                @db.UnsignedInt
  payload_text        String             @db.LongText
  recipients_snapshot String             @db.Text
  transport_status    String             @db.VarChar(20)
  transport_response  String?            @db.LongText
  sent_at             DateTime?          @db.DateTime(0)
  created_at          DateTime           @default(now()) @db.Timestamp(0)
  updated_at          DateTime           @default(now()) @updatedAt @db.Timestamp(0)
  rule                alert_method_rules @relation(fields: [rule_id], references: [id], onDelete: Cascade, map: "fk_alert_dispatch_rule")

  @@unique([rule_id, signal_key], map: "uq_alert_dispatch_rule_signal")
  @@index([rule_id, created_at], map: "idx_alert_dispatch_rule_created")
  @@index([transport_status, created_at], map: "idx_alert_dispatch_status_created")
}

