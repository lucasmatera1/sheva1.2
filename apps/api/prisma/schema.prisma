model alert_method_rules {
  id                BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  name              String                   @db.VarChar(150)
  is_active         Boolean                  @default(true)
  transport_channel String                   @default("webhook") @db.VarChar(16)
  league_type       String                   @db.VarChar(32)
  method_code       String                   @db.VarChar(16)
  series            String?                  @db.VarChar(1)
  player_name       String?                  @db.VarChar(120)
  apx_min           Decimal                  @default(0.00) @db.Decimal(5, 2)
  min_occurrences   Int                      @default(1) @db.UnsignedInt
  window_days       Int                      @default(30) @db.UnsignedSmallInt
  recipients        String                   @db.Text
  webhook_url       String?                  @db.VarChar(500)
  note              String?                  @db.VarChar(255)
  created_at        DateTime                 @default(now()) @db.Timestamp(0)
  updated_at        DateTime                 @default(now()) @updatedAt @db.Timestamp(0)
  last_evaluated_at DateTime?                @db.DateTime(0)
  dispatches        alert_method_dispatches[]

  @@index([is_active, league_type, method_code], map: "idx_alert_rules_active_method")
  @@index([player_name], map: "idx_alert_rules_player_name")
}

