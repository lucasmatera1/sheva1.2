{
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.enablePersistentSessions": false,

  // Python / Pylance
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps/odds-radar"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  // Editor
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Prisma
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },

  // Files
  "files.exclude": {
    "**/__pycache__": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/.venv_old": true,
    "**/dist": true,
    "**/.next": true,
    "**/.turbo": true
  },

  // Copilot — terminais abrem inline no chat
  "github.copilot.chat.runCommand.terminalChatParticipant": true,
  "chat.tools.terminal.autoApprove": {
    "/^& \"d:\\\\Sheva\\\\\\.venv\\\\Scripts\\\\python\\.exe\" \"d:\\\\Sheva\\\\apps\\\\odds-radar\\\\scripts\\\\test_multi_bet\\.py\" --count 3 --stake 1\\.00 --delay 5$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}